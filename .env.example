# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend API URL (AI calls are now handled by the backend)
VITE_API_URL=http://localhost:3001

# ─── AI Keys (MOVED TO BACKEND) ──────────────────
# AI API keys are NO LONGER needed here.
# Configure them in backend/.env instead.
# The frontend now proxies all AI requests through the backend.
